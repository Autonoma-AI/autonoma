{
    "name": "@autonoma/billing",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./env": "./src/env.ts",
        "./types": "./src/types.ts"
    },
    "scripts": {
        "build": "tsc --noCheck",
