{
    "name": "@autonoma/visual-ai",
    "version": "1.0.0",
    "description": "Screenshot-driven AI primitives: visual checkers and point/object detection. Depends on sharp via @autonoma/image.",
    "keywords": [],
    "license": "ISC",
    "author": "",
    "type": "module",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "test": "vitest",
        "eval": "vitest --config vitest.eval.config.ts",
        "lint-files": "oxlint --fix",
        "lint": "pnpm lint-files .",
        "fmt": "oxfmt --write src/",
        "build": "tsc --noCheck",
        "typecheck": "tsc --noEmit",
        "detect-object": "tsx --env-file=.env scripts/detect-object.ts"
    },
    "dependencies": {
        "@autonoma/ai": "workspace:*",
        "@autonoma/errors": "workspace:*",
        "@autonoma/image": "workspace:*",
        "@google/genai": "^1.42.0",
        "ai": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@autonoma/logger": "workspace:*",
        "dotenv": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
