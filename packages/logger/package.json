{
    "name": "@autonoma/logger",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        },
        "./env": "./src/env.ts",
        "./build-log-event": {
            "types": "./src/build-log-event.ts",
            "import": "./src/build-log-event.ts"
        },
        "./build-log-sink": {
            "types": "./src/build-log-sink.ts",
            "import": "./src/build-log-sink.ts"
        },
        "./loki-build-log-sink": {
            "types": "./src/loki-build-log-sink.ts",
            "import": "./src/loki-build-log-sink.ts"
        },
        "./log-store": {
            "types": "./src/log-store.ts",
            "import": "./src/log-store.ts"
        },
        "./loki-log-store": {
            "types": "./src/loki-log-store.ts",
            "import": "./src/loki-log-store.ts"
        }
    },
    "scripts": {
        "build": "tsc --noCheck",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint --fix src/",
        "fmt": "oxfmt --write src/",
        "test": "vitest run --passWithNoTests",
        "test:integration": "vitest run --config vitest.integration.config.ts"
    },
    "dependencies": {
        "@sentry/node": "catalog:",
        "@t3-oss/env-core": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "dotenv": "catalog:",
        "testcontainers": "^11.12.0",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
