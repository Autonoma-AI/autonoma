{
    "name": "@autonoma/db-evals",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "build": "tsc --noCheck",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint --fix src/",
        "fmt": "oxfmt --write src/",
        "db": "dotenv -e ../../.env -- prisma",
        "db:generate": "DATABASE_EVALS_URL=${DATABASE_EVALS_URL:-postgres://postgres:postgres@localhost:5432/evals} pnpm db generate",
        "postinstall": "pnpm db:generate",
        "db:migrate": "pnpm db migrate dev"
    },
    "dependencies": {
        "@prisma/adapter-pg": "catalog:",
        "@prisma/client": "catalog:",
        "@t3-oss/env-core": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "dotenv": "catalog:",
        "dotenv-cli": "^11.0.0",
        "prisma": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:"
    }
}
