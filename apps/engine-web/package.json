{
    "name": "@autonoma/engine-web",
    "version": "0.0.1",
    "private": true,
    "description": "Playwright-based web engine for the Autonoma testing platform",
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./generation": "./src/execution-agent/generation-api/run-generation-job.ts",
        "./web-installer": "./src/platform/web-installer.ts",
        "./web-agent-factory": "./src/execution-agent/web-agent/web-agent-factory.ts"
    },
    "scripts": {
        "build": "tsc --noCheck",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint --fix src/",
        "fmt": "oxfmt --write src/",
        "test": "vitest run --passWithNoTests",
        "eval": "RUN_EVALS=true vitest run --passWithNoTests",
        "eval:generation": "RUN_EVALS=true vitest run evals/generation/generation.eval.ts",
        "dev": "tsx --env-file=../../.env src/execution-agent/local-dev/run-execution.ts",
        "run-generation": "tsx --env-file=../../.env src/execution-agent/generation-api/run-generation-job.ts"
    },
    "dependencies": {
        "@autonoma/ai": "workspace:*",
        "@autonoma/db": "workspace:*",
        "@autonoma/engine": "workspace:*",
        "@autonoma/errors": "workspace:*",
        "@autonoma/evals": "workspace:*",
        "@autonoma/image": "workspace:*",
        "@autonoma/logger": "workspace:*",
        "@autonoma/scenario": "workspace:*",
        "@autonoma/storage": "workspace:*",
        "@autonoma/types": "workspace:*",
        "@autonoma/utils": "workspace:*",
        "@autonoma/visual-ai": "workspace:*",
        "@ffmpeg-installer/ffmpeg": "^1.1.0",
        "@google/genai": "^1.42.0",
        "@sentry/node": "catalog:",
        "@t3-oss/env-core": "catalog:",
        "ai": "catalog:",
        "dotenv": "catalog:",
        "playwright": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
