        "@temporalio/activity": "^1.11.7",
        "@temporalio/worker": "^1.11.7"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "dotenv": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
