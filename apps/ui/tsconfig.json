{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": ".",
        "jsx": "react-jsx",
        "declaration": false,
        "declarationMap": false,
        "types": ["vite/client"],
        "allowImportingTsExtensions": true,
        "paths": {
            "components/*": ["./src/components/*"],
            "hooks/*": ["./src/hooks/*"],
            "lib/*": ["./src/lib/*"],
            "routes/*": ["./src/routes/*"],
            "env": ["./src/env.ts"]
        }
    },
    "include": ["src", ".storybook"]
}
